# 포트 (서비스마다 다르게 설정)
server.port=8081

# 이 서비스의 이름 (게이트웨이 라우팅 uri에 쓴 이름과 일치해야 함!)
spring.application.name=auth-service

# 유레카 서버에 등록
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/

# DB 연결 설정
spring.datasource.url=jdbc:mysql://localhost:3306/plantcare
spring.datasource.username=root
spring.datasource.password=${DB_PASSWORD:root}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA 설정
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# JWT 시크릿 (HS256: 최소 32바이트). 운영 환경에서는 반드시 JWT_SECRET 환경변수로 주입할 것.
jwt.secret=${JWT_SECRET:plantcare-secret-key-must-be-at-least-32-characters}

# 프로필 이미지 업로드 디렉토리 (상대 경로는 user-service 작업 디렉토리 기준)
file.upload-dir=./uploads/profile-images

# 멀티파트 설정 (프로필 이미지 업로드)
spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
