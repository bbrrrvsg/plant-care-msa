# 게이트웨이 서버 포트
server.port=8080

spring.application.name=gateway-service

eureka.client.service-url.defaultZone=http://localhost:8761/eureka/

# ── CORS 전역 설정 ──
spring.cloud.gateway.globalcors.cors-configurations.[/**].allowed-origins=*
spring.cloud.gateway.globalcors.cors-configurations.[/**].allowed-methods=GET,POST,PUT,DELETE,OPTIONS
spring.cloud.gateway.globalcors.cors-configurations.[/**].allowed-headers=*
spring.cloud.gateway.globalcors.cors-configurations.[/**].allow-credentials=false

# ── 라우팅 설정 ──
spring.cloud.gateway.server.webmvc.routes[0].id=auth-service
spring.cloud.gateway.server.webmvc.routes[0].uri=lb://AUTH-SERVICE
spring.cloud.gateway.server.webmvc.routes[0].predicates[0]=Path=/auth/**

spring.cloud.gateway.server.webmvc.routes[1].id=plant-service
spring.cloud.gateway.server.webmvc.routes[1].uri=lb://PLANT-SERVICE
spring.cloud.gateway.server.webmvc.routes[1].predicates[0]=Path=/plant/**

spring.cloud.gateway.server.webmvc.routes[2].id=sensor-service
spring.cloud.gateway.server.webmvc.routes[2].uri=lb://SENSOR-SERVICE
spring.cloud.gateway.server.webmvc.routes[2].predicates[0]=Path=/sensor/**

spring.cloud.gateway.server.webmvc.routes[3].id=ai-service
spring.cloud.gateway.server.webmvc.routes[3].uri=lb://AI-SERVICE
spring.cloud.gateway.server.webmvc.routes[3].predicates[0]=Path=/ai/**

spring.cloud.gateway.server.webmvc.routes[4].id=diagnosis-service
spring.cloud.gateway.server.webmvc.routes[4].uri=lb://AI-SERVICE
spring.cloud.gateway.server.webmvc.routes[4].predicates[0]=Path=/diagnosis/**

spring.cloud.gateway.server.webmvc.routes[5].id=weather
spring.cloud.gateway.server.webmvc.routes[5].uri=lb://PLANT-SERVICE
spring.cloud.gateway.server.webmvc.routes[5].predicates[0]=Path=/weather/**

spring.cloud.gateway.server.webmvc.routes[6].id=images
spring.cloud.gateway.server.webmvc.routes[6].uri=lb://PLANT-SERVICE
spring.cloud.gateway.server.webmvc.routes[6].predicates[0]=Path=/images/**

spring.cloud.gateway.server.webmvc.routes[7].id=profile-images
spring.cloud.gateway.server.webmvc.routes[7].uri=lb://AUTH-SERVICE
spring.cloud.gateway.server.webmvc.routes[7].predicates[0]=Path=/profile-images/**

spring.cloud.gateway.mvc.forwarded-headers-strategy=native

spring.servlet.multipart.enabled=true
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB
