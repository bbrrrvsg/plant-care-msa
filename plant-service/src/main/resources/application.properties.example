server.port=8082
spring.application.name=plant-service
eureka.client.service-url.defaultZone=http://localhost:8761/eureka/
spring.datasource.url=jdbc:mysql://localhost:3306/plantcare
spring.datasource.username=root
spring.datasource.password=${DB_PASSWORD:root}
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true

# 성장 일지 사진 업로드 경로 (상대 경로는 plant-service 작업 디렉토리 기준).
# /images/** 정적 핸들러가 이 디렉토리를 노출합니다.
file.upload-dir=./uploads/plant-images

# 멀티파트 업로드 제한
spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=10MB

# 외부 API 키 - 본인 값으로 채우기
perenual.api.key=${PERENUAL_API_KEY:}
nongsaro.api.key=${NONGSARO_API_KEY:}
# OpenWeatherMap API 키 (비어있으면 Mock 데이터 반환)
openweather.api.key=${OPENWEATHER_API_KEY:}

# 도감 데이터 강제 재로딩 플래그
# true로 설정 후 1회 부팅하면 plant_book 테이블을 농사로 API에서 다시 받아 덮어씁니다.
# (스키마 변경 등으로 기존 row를 갱신해야 할 때만 켜고, 끝나면 false로 되돌릴 것)
plant.book.reload=false
